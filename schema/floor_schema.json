{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FloorSchema",
  "type": "object",
  "required": [
    "id",
    "canonical_name",
    "sanskrit_name",
    "alternate_names",
    "classification",
    "canonical",
    "comparative",
    "science",
    "phenomenology",
    "memory",
    "sources",
    "gateway_experience"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^floor_([1-9]|1[0-8])$" },
    "canonical_name": { "type": "string" },
    "sanskrit_name": { "type": "string" },
    "alternate_names": {
      "type": "array",
      "items": { "type": "string" }
    },
    "classification": {
      "type": "object",
      "required": ["level", "realm", "category"],
      "properties": {
        "level": { "type": "integer", "minimum": 1, "maximum": 18 },
        "realm": { "type": "string", "enum": ["Pinda", "Brahmanda", "Dayal Desh", "Secret"] },
        "category": { "type": "string", "enum": ["physical", "astral", "pure spirit", "indescribable"] }
      }
    },
    "canonical": {
      "type": "object",
      "required": ["ruler", "sound", "light", "geometry", "petals", "teachings"],
      "properties": {
        "ruler": { "type": "string" },
        "sound": { "type": "string" },
        "light": { "type": "string" },
        "geometry": { "type": "string" },
        "petals": {
          "type": "object",
          "required": ["count", "color", "seed_syllables"],
          "properties": {
            "count": { "type": "integer" },
            "color": { "type": "string" },
            "seed_syllables": { "type": "array", "items": { "type": "string" } }
          }
        },
        "teachings": { "type": "string" },
        "mantra": { "type": "string" },
        "recitation": { "type": "string" },
        "consorts": { "type": "string" },
        "function": { "type": "string" }
      }
    },
    "comparative": {
      "type": "object",
      "properties": {
        "sufism": {
          "type": "object",
          "properties": {
            "term": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "taoism": {
          "type": "object",
          "properties": {
            "term": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "kabbalah": {
          "type": "object",
          "properties": {
            "term": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "buddhism": {
          "type": "object",
          "properties": {
            "term": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "christianity": {
          "type": "object",
          "properties": {
            "term": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "gnosticism": {
          "type": "object",
          "properties": {
            "term": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "hindu_tantra": {
          "type": "object",
          "properties": {
            "term": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "sikhism": {
          "type": "object",
          "properties": {
            "term": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "vedic": {
          "type": "object",
          "properties": {
            "term": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "jainism": {
          "type": "object",
          "properties": {
            "term": { "type": "string" },
            "description": { "type": "string" }
          }
        }
      }
    },
    "science": {
      "type": "object",
      "properties": {
        "neuroscience": {
          "type": "object",
          "properties": {
            "regions": { "type": "array", "items": { "type": "string" } },
            "networks": { "type": "array", "items": { "type": "string" } },
            "description": { "type": "string" },
            "confidence": { "type": "string", "enum": ["High", "Medium", "Low"] }
          }
        },
        "endocrinology": {
          "type": "object",
          "properties": {
            "description": { "type": "string" }
          }
        },
        "psychology": {
          "type": "object",
          "properties": {
            "ego_state": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "cosmology": {
          "type": "object",
          "properties": {
            "description": { "type": "string" }
          }
        },
        "information_theory": {
          "type": "object",
          "properties": {
            "description": { "type": "string" }
          }
        }
      }
    },
    "phenomenology": {
      "type": "object",
      "required": ["emotional_tone", "visual_texture", "auditory_texture", "ego_effect", "risks", "transitions"],
      "properties": {
        "emotional_tone": { "type": "string" },
        "visual_texture": { "type": "string" },
        "auditory_texture": { "type": "string" },
        "ego_effect": { "type": "string" },
        "risks": { "type": "string" },
        "transitions": {
          "type": "object",
          "required": ["from_previous", "to_next"],
          "properties": {
            "from_previous": { "type": "string" },
            "to_next": { "type": "string" }
          }
        }
      }
    },
    "memory": {
      "type": "object",
      "required": ["color", "icon", "metaphor", "mnemonic"],
      "properties": {
        "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "icon": { "type": "string" },
        "metaphor": { "type": "string" },
        "mnemonic": { "type": "string" }
      }
    },
    "sources": {
      "type": "object",
      "required": ["primary", "secondary"],
      "properties": {
        "primary": { "type": "array", "items": { "type": "string" } },
        "secondary": { "type": "array", "items": { "type": "string" } }
      }
    },
    "gateway_experience": {
      "type": "object",
      "required": ["tradition", "epistemic_label", "tapes", "bridge_note", "tape_count"],
      "properties": {
        "tradition": { "type": "string" },
        "epistemic_label": { "type": "string" },
        "tapes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["tape_num", "name", "wave", "wave_num", "focus", "state", "brainwave", "hz", "description", "confidence"],
            "properties": {
              "tape_num": { "type": "integer" },
              "name": { "type": "string" },
              "wave": { "type": "string" },
              "wave_num": { "type": "integer" },
              "focus": { "type": "string" },
              "state": { "type": "string" },
              "brainwave": { "type": "string" },
              "hz": { "type": "string" },
              "description": { "type": "string" },
              "confidence": { "type": "string", "enum": ["Very Strong", "Strong", "Approximate", "Speculative"] }
            }
          }
        },
        "bridge_note": { "type": "string" },
        "map_limit_note": { "type": "string" },
        "tape_count": { "type": "integer" }
      }
    }
  }
}
